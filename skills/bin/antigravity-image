#!/usr/bin/env bash
# Thin wrapper for the antigravity_image skill. Installed into the OpenClaw workspace
# `bin/` dir; self-locates the skill script at ../skills/antigravity_image/scripts/gen.py.
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec python3 "$HERE/../skills/antigravity_image/scripts/gen.py" "$@"
